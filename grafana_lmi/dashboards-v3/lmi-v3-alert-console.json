    {
      "id": 13,
      "type": "table",
      "title": "Recent Critical & Warning Alerts",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 6},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "lmi_sqlite"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT created_at_utc, category, severity, UPPER(title) AS title, UPPER(status) AS status FROM alert_messages WHERE severity >= 5 ORDER BY created_at_utc DESC LIMIT 20;",
          "rawQueryText": "SELECT created_at_utc, category, severity, UPPER(title) AS title, UPPER(status) AS status FROM alert_messages WHERE severity >= 5 ORDER BY created_at_utc DESC LIMIT 20;"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "severity"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 5},
                  {"color": "orange", "value": 7},
                  {"color": "red", "value": 8}
                ]
              }},
              {"id": "custom.align", "value": "center"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "status"},
            "properties": [
              {"id": "custom.width", "value": 100},
              {"id": "custom.align", "value": "center"},
              {"id": "mappings", "value": [
                {"type": "value", "options": {"OPEN": {"text": "OPEN", "color": "red"}, "ACKED": {"text": "ACKED", "color": "yellow"}, "CLOSED": {"text": "CLOSED", "color": "green"}}}
              ]}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {"displayName": "created_at_utc", "desc": true}
        ]
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Alert Volume (90d)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 5},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "lmi_sqlite"},
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "queryType": "time_series",
          "queryText": "SELECT DATE(created_at_utc) AS time, COUNT(*) AS value FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-90 day') GROUP BY DATE(created_at_utc) ORDER BY time;",
          "rawQueryText": "SELECT DATE(created_at_utc) AS time, COUNT(*) AS value FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-90 day') GROUP BY DATE(created_at_utc) ORDER BY time;"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0},
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "table",
      "title": "Alert Resolution Time by Category",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 5},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "lmi_sqlite"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT category, COUNT(*) AS total_alerts, SUM(CASE WHEN status = 'closed' THEN 1 ELSE 0 END) AS closed, ROUND(AVG(CASE WHEN status = 'closed' THEN CAST(julianday(updated_at_utc) - julianday(created_at_utc) * 24 AS REAL) END), 2) AS avg_hours_to_close FROM alert_messages WHERE created_at_utc >= DATE('now', '-30 day') GROUP BY category;",
          "rawQueryText": "SELECT category, COUNT(*) AS total_alerts, SUM(CASE WHEN status = 'closed' THEN 1 ELSE 0 END) AS closed, ROUND(AVG(CASE WHEN status = 'closed' THEN CAST(julianday(updated_at_utc) - julianday(created_at_utc) * 24 AS REAL) END), 2) AS avg_hours_to_close FROM alert_messages WHERE created_at_utc >= DATE('now', '-30 day') GROUP BY category;"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "avg_hours_to_close"}, "properties": [{"id": "unit", "value": "h"}, {"id": "decimals", "value": 1}]}
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
