          {"matcher": {"id": "byName", "options": "market_value"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "holdings_count"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 0}]}
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Period Summary by Type",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "lmi_sqlite"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT period_type, is_rolling, COUNT(*) AS count, MAX(as_of_date_local) AS last_date FROM period_summary GROUP BY period_type, is_rolling ORDER BY period_type, is_rolling;",
          "rawQueryText": "SELECT period_type, is_rolling, COUNT(*) AS count, MAX(as_of_date_local) AS last_date FROM period_summary GROUP BY period_type, is_rolling ORDER BY period_type, is_rolling;"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "is_rolling"}, "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "Fixed"}, "1": {"text": "Rolling"}}}]}]},
          {"matcher": {"id": "byName", "options": "count"}, "properties": [{"id": "unit", "value": "short"}, {"id": "custom.align", "value": "center"}]}
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
