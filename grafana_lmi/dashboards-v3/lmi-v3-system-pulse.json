      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "lmi_sqlite"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT as_of_date_local, market_value, holdings_count, created_at_utc FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 10;",
          "rawQueryText": "SELECT as_of_date_local, market_value, holdings_count, created_at_utc FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 10;"
        }
      ],
      "fieldConfig": {
        "defaults": {},
