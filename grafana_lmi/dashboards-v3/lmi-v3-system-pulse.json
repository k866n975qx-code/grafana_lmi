          "queryType": "time_series",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, COUNT(*) AS value FROM daily_portfolio WHERE as_of_date_local >= date('now','-90 day') GROUP BY as_of_date_local ORDER BY as_of_date_local;",
          "rawQueryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, COUNT(*) AS value FROM daily_portfolio WHERE as_of_date_local >= date('now','-90 day') GROUP BY as_of_date_local ORDER BY as_of_date_local;"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0},
        "overrides": []
      }
