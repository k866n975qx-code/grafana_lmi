          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT UPPER(tail_risk_category) AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;",
          "rawQueryText": "SELECT UPPER(tail_risk_category) AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
