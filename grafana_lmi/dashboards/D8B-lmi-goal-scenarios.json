      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT tier AS \"Tier\", name AS \"Name\", ROUND(target_monthly, 0) AS \"Target $\", ROUND(required_portfolio_value, 0) AS \"Required MV\", ROUND(months_to_goal, 0) AS \"Months\", ROUND(confidence, 2) AS \"Confidence\", ROUND(assumption_monthly_contribution, 0) AS \"Contrib $\", CASE WHEN assumption_drip_enabled = 1 THEN 'Yes' ELSE 'No' END AS \"DRIP\", ROUND(assumption_annual_appreciation_pct, 1) AS \"Appr %\", CASE WHEN assumption_ltv_maintained = 1 THEN 'Yes' ELSE 'No' END AS \"LTV\", ROUND(assumption_target_ltv_pct, 1) AS \"Target LTV\" FROM daily_goal_tiers WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_goal_tiers) ORDER BY tier;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
