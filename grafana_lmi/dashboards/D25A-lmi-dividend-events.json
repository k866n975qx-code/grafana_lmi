    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Dividend Events (Week)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT pde.symbol AS \"Symbol\", pde.ex_date AS \"Ex Date\", pde.pay_date AS \"Pay Date\", ROUND(pde.amount, 2) AS \"Amount\", COALESCE(UPPER(dh.distribution_frequency), 'N/A') AS \"Freq\" FROM period_dividend_events pde LEFT JOIN daily_holdings dh ON dh.symbol = pde.symbol AND dh.as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) WHERE pde.period_type = 'week' AND pde.period_end_date = (SELECT MAX(period_end_date) FROM period_dividend_events WHERE period_type = 'week') ORDER BY pde.ex_date DESC;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Symbol": 0,
              "Ex Date": 1,
              "Pay Date": 2,
              "Amount": 3,
              "Freq": 4
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Symbol"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Ex Date"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pay Date"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Amount"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Freq"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Week Dividend Count",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM period_dividend_events WHERE period_type = 'week' AND period_end_date = (SELECT MAX(period_end_date) FROM period_dividend_events WHERE period_type = 'week');"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Week Dividend Total",
      "gridPos": {
        "x": 6,
        "y": 12,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(SUM(amount), 2) AS value FROM period_dividend_events WHERE period_type = 'week' AND period_end_date = (SELECT MAX(period_end_date) FROM period_dividend_events WHERE period_type = 'week');"
        }
      ],
      "fieldConfig": {
        "defaults": {
