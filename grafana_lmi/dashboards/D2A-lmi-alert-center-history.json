{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Alerts (30d)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-30 day');"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Resolved (30d)",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM alert_messages WHERE status = 'closed' AND DATE(updated_at_utc) >= DATE('now', '-30 day');"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Resolution (hrs)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(AVG((julianday(updated_at_utc) - julianday(created_at_utc)) * 24), 1) AS value FROM alert_messages WHERE status = 'closed' AND updated_at_utc IS NOT NULL;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical Resolved",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM alert_messages WHERE status = 'closed' AND severity >= 8 AND DATE(updated_at_utc) >= DATE('now', '-30 day');"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Alert History by Category",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 5
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT category AS \"Category\", COUNT(*) AS \"Total\", SUM(CASE WHEN status = 'open' THEN 1 ELSE 0 END) AS \"Open\", SUM(CASE WHEN status = 'closed' AND DATE(updated_at_utc) >= DATE('now', '-30 day') THEN 1 ELSE 0 END) AS \"Resolved\", ROUND(AVG(CASE WHEN status = 'closed' THEN (julianday(updated_at_utc) - julianday(created_at_utc)) * 24 END), 1) AS \"Avg Hours\" FROM alert_messages GROUP BY category ORDER BY \"Total\" DESC;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Category": 0,
              "Total": 1,
              "Open": 2,
              "Resolved": 3,
              "Avg Hours": 4
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Category"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Open"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Hours"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Alert Trend (30d)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT DATE(created_at_utc) AS time, SUM(CASE WHEN severity >= 8 THEN 1 ELSE 0 END) AS \"Critical\", SUM(CASE WHEN severity BETWEEN 5 AND 7 THEN 1 ELSE 0 END) AS \"Warning\", SUM(CASE WHEN severity <= 4 THEN 1 ELSE 0 END) AS \"Info\" FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-30 day') GROUP BY DATE(created_at_utc) ORDER BY time;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lmi",
    "alerts"
  ],
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "D2A - LMI - Alert Center: History",
  "uid": "lmi-d2a-alert-center-history",
  "version": 1,
  "__annotations": {
    "grafana.app/sourcePath": "dashboards/D2A-lmi-alert-center-history.json"
  }
}
