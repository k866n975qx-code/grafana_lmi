{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Rate Shock Scenarios",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT scenario AS \"Scenario\", ROUND(new_rate_pct, 2) AS \"New Rate %\", ROUND(new_monthly_cost, 2) AS \"New Monthly $\", ROUND(income_coverage, 2) AS \"Coverage\", ROUND(margin_impact_pct, 1) AS \"Impact %\" FROM daily_margin_rate_scenarios WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_margin_rate_scenarios) ORDER BY CASE scenario WHEN '+100bp' THEN 1 WHEN '+200bp' THEN 2 WHEN '+300bp' THEN 3 END;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Scenario": 0,
              "New Rate %": 1,
              "New Monthly $": 2,
              "Coverage": 3,
              "Impact %": 4
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Scenario"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "New Rate %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "New Monthly $"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Coverage"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Impact %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Scenario Impact Trend (90d)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, ROUND(MAX(CASE WHEN scenario = '+100bp' THEN margin_impact_pct END), 1) AS \"+100bp %\", ROUND(MAX(CASE WHEN scenario = '+200bp' THEN margin_impact_pct END), 1) AS \"+200bp %\", ROUND(MAX(CASE WHEN scenario = '+300bp' THEN margin_impact_pct END), 1) AS \"+300bp %\" FROM daily_margin_rate_scenarios WHERE as_of_date_local >= date('now','-90 day') GROUP BY as_of_date_local ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    }
  ],
  "refresh": "2m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lmi",
    "margin"
  ],
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "D30A - LMI - Margin Scenarios",
  "uid": "lmi-d30a-margin-scenarios",
  "version": 1,
  "__annotations": {
    "grafana.app/sourcePath": "dashboards/D30A-lmi-margin-scenarios.json"
  }
}
