      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (strftime('%s', as_of_date_local || ' 00:00:00') * 1000) AS time, SUM(CASE WHEN category='income' THEN 1 ELSE 0 END) AS Income, SUM(CASE WHEN category='ex_dividend' THEN 1 ELSE 0 END) AS ExDividend, SUM(CASE WHEN category NOT IN ('income','ex_dividend') THEN 1 ELSE 0 END) AS Other FROM alert_messages WHERE as_of_date_local >= date('now','-120 day') GROUP BY as_of_date_local ORDER BY as_of_date_local",
          "rawQueryText": "SELECT (strftime('%s', as_of_date_local || ' 00:00:00') * 1000) AS time, SUM(CASE WHEN category='income' THEN 1 ELSE 0 END) AS Income, SUM(CASE WHEN category='ex_dividend' THEN 1 ELSE 0 END) AS ExDividend, SUM(CASE WHEN category NOT IN ('income','ex_dividend') THEN 1 ELSE 0 END) AS Other FROM alert_messages WHERE as_of_date_local >= date('now','-120 day') GROUP BY as_of_date_local ORDER BY as_of_date_local"
        }
