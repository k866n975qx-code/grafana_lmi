    {
      "id": 9,
      "type": "timeseries",
      "title": "Alerts by Category per Day",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
