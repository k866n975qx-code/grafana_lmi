    {
      "id": 5,
      "type": "timeseries",
      "title": "CVaR Trend (180d)",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, cvar_95_1d_pct AS \"CVaR 95 1d %\", cvar_95_1w_pct AS \"CVaR 95 1w %\", cvar_95_1m_pct AS \"CVaR 95 1m %\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-180 day') AND cvar_95_1d_pct IS NOT NULL ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "VaR/CVaR Summary",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 5
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH latest AS (SELECT * FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1) SELECT 'VaR 95' AS Metric, ROUND(var_95_1d_pct, 2) AS \"1d\", ROUND(var_95_1w_pct, 2) AS \"1w\", ROUND(var_95_1m_pct, 2) AS \"1m\" FROM latest UNION ALL SELECT 'CVaR 95', ROUND(cvar_95_1d_pct, 2), ROUND(cvar_95_1w_pct, 2), ROUND(cvar_95_1m_pct, 2) FROM latest UNION ALL SELECT 'VaR 99', ROUND(var_99_1d_pct, 2), NULL, NULL FROM latest UNION ALL SELECT 'CVaR 99', ROUND(cvar_99_1d_pct, 2), NULL, NULL FROM latest;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Metric": 0,
              "1d": 1,
              "1w": 2,
              "1m": 3
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Metric"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "1d"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "1w"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "1m"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      }
    }
  ],
