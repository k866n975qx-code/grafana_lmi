      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(symbol,1,8) AS Sym, round(weight_pct,2) AS WtPct, round(vol_30d_pct,2) AS Vol30, round(sharpe_1y,2) AS Sharpe, round(sortino_1y,2) AS Sortino, substr(COALESCE(risk_quality_category,''),1,16) AS Risk FROM daily_holdings WHERE as_of_date_local=(SELECT d FROM d) ORDER BY weight_pct DESC LIMIT 5",
          "rawQueryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(symbol,1,8) AS Sym, round(weight_pct,2) AS WtPct, round(vol_30d_pct,2) AS Vol30, round(sharpe_1y,2) AS Sharpe, round(sortino_1y,2) AS Sortino, substr(COALESCE(risk_quality_category,''),1,16) AS Risk FROM daily_holdings WHERE as_of_date_local=(SELECT d FROM d) ORDER BY weight_pct DESC LIMIT 5"
        }
