      "type": "timeseries",
      "title": "Goal Progress % vs Net Progress %",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "queryType": "timeSeriesQuery",
          "queryText": "SELECT CAST(strftime('%s', as_of_date_local) AS INTEGER) AS time, goal_progress_pct AS \"Goal Progress %\", goal_net_progress_pct AS \"Net Progress %\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-120 day') ORDER BY as_of_date_local",
