      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_goal_tiers) SELECT tier AS Tier, substr(COALESCE(name,''),1,16) AS Name, round(target_monthly,0) AS TargetMo, round(months_to_goal,1) AS Months FROM daily_goal_tiers WHERE as_of_date_local=(SELECT d FROM d) ORDER BY tier LIMIT 5",
          "rawQueryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_goal_tiers) SELECT tier AS Tier, substr(COALESCE(name,''),1,16) AS Name, round(target_monthly,0) AS TargetMo, round(months_to_goal,1) AS Months FROM daily_goal_tiers WHERE as_of_date_local=(SELECT d FROM d) ORDER BY tier LIMIT 5"
