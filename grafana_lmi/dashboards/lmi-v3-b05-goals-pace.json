    {
      "id": 12,
      "type": "table",
      "title": "Period Goal Deltas",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH latest AS (SELECT period_type, MAX(period_end_date) AS period_end_date FROM period_summary WHERE is_rolling=0 GROUP BY period_type) SELECT ps.period_type AS PType, ps.period_end_date AS EndDate, round(ps.goal_progress_pct_delta,2) AS GoalDelta, round(ps.goal_months_to_goal_delta,2) AS MonthsDelta FROM period_summary ps JOIN latest l ON l.period_type=ps.period_type AND l.period_end_date=ps.period_end_date ORDER BY CASE ps.period_type WHEN 'WEEK' THEN 1 WHEN 'MONTH' THEN 2 WHEN 'QUARTER' THEN 3 WHEN 'YEAR' THEN 4 ELSE 5 END LIMIT 5",
          "rawQueryText": "WITH latest AS (SELECT period_type, MAX(period_end_date) AS period_end_date FROM period_summary WHERE is_rolling=0 GROUP BY period_type) SELECT ps.period_type AS PType, ps.period_end_date AS EndDate, round(ps.goal_progress_pct_delta,2) AS GoalDelta, round(ps.goal_months_to_goal_delta,2) AS MonthsDelta FROM period_summary ps JOIN latest l ON l.period_type=ps.period_type AND l.period_end_date=ps.period_end_date ORDER BY CASE ps.period_type WHEN 'WEEK' THEN 1 WHEN 'MONTH' THEN 2 WHEN 'QUARTER' THEN 3 WHEN 'YEAR' THEN 4 ELSE 5 END LIMIT 5"
        }
