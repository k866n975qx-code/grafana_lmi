{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CVaR to Income Ratio",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT cvar_to_income_ratio AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max DD 1y %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT max_drawdown_1y_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DD Duration Days",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT drawdown_duration_1y_days AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ulcer Index",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ulcer_index_1y AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Drawdown Depth 180d",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, drawdown_depth_pct AS value FROM daily_portfolio WHERE as_of_date_local >= date('now','-180 day') ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CVaR 95 1d 180d",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, cvar_95_1d_pct AS value FROM daily_portfolio WHERE as_of_date_local >= date('now','-180 day') AND cvar_95_1d_pct IS NOT NULL ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "VaR/CVaR Summary",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT 'VaR 95' AS Metric, ROUND(var_95_1d_pct, 2) AS \"1d\", ROUND(var_95_1w_pct, 2) AS \"1w\", ROUND(var_95_1m_pct, 2) AS \"1m\" FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1 UNION ALL SELECT 'CVaR 95', ROUND(cvar_95_1d_pct, 2), ROUND(cvar_95_1w_pct, 2), ROUND(cvar_95_1m_pct, 2) FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Metric": 0, "1d": 1, "1w": 2, "1m": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Metric" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "1d" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "1w" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "1m" }, "properties": [{ "id": "custom.width", "value": 150 }] }
        ]
      }
    }
  ],
  "refresh": "2m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "risk"],
  "time": { "from": "now-180d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Command Surface: Risk Detail",
  "uid": "lmi-command-surface-risk-detail",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-command-surface-risk-detail.json" }
}
