      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(pnl_pct_period, 2) AS \"P&L %\", ROUND(pnl_dollar_period, 2) AS \"P&L $\", ROUND(contribution_to_portfolio_pct, 2) AS \"Contribution %\", ROUND(start_shares, 2) AS \"Start Shares\", ROUND(end_shares, 2) AS \"End Shares\", ROUND(shares_delta, 2) AS \"Share Delta\" FROM period_holding_changes WHERE period_type = 'week' AND period_end_date = (SELECT MAX(period_end_date) FROM period_holding_changes WHERE period_type = 'week') ORDER BY pnl_pct_period DESC;"
        }
      ],
