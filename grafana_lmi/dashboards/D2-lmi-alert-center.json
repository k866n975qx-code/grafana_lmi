      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT DATE(created_at_utc) AS time, COUNT(*) AS \"Alerts\" FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-30 day') GROUP BY DATE(created_at_utc) ORDER BY time;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
