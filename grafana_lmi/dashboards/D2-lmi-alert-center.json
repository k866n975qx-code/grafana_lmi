    {
      "id": 13,
      "type": "table",
      "title": "Recent Alerts (Sev 5+)",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 5
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT SUBSTR(created_at_utc, 1, 16) AS \"Time\", category AS \"Category\", severity AS \"Sev\", UPPER(title) AS \"Alert\", UPPER(status) AS \"Status\" FROM alert_messages WHERE severity >= 5 ORDER BY created_at_utc DESC LIMIT 15;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": false
            },
            "indexByName": {
              "Time": 0,
              "Category": 1,
              "Sev": 2,
              "Alert": 3,
              "Status": 4
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Category"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Sev"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 60
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      }
