        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT portfolio_yield_on_cost_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
