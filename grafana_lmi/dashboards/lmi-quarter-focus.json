{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Quarter Label",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT period_label AS value FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "string" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Quarter MV Delta",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT mv_delta AS value FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Quarter TWR",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT twr_period_pct AS value FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dividends",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT dividends_received_period AS value FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Quarterly MV",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (interval_end || 'T00:00:00Z') AS time, mv AS \"MV\" FROM period_intervals WHERE period_type = 'quarter' ORDER BY interval_end DESC LIMIT 8;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Quarterly History",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT period_label AS \"Quarter\", period_end_date AS \"End\", ROUND(mv_delta, 0) AS \"MV $\", ROUND(twr_period_pct, 2) AS \"TWR %\", ROUND(dividends_received_period, 2) AS \"Div $\" FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 8;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Quarter": 0, "End": 1, "MV $": 2, "TWR %": 3, "Div $": 4 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Quarter" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "End" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "MV $" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "TWR %" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Div $" }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "periods"],
  "time": { "from": "now-4y", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Quarter Focus",
  "uid": "lmi-quarter-focus",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-quarter-focus.json" }
}
