      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(SUM(amount), 2) AS value FROM period_dividend_events WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_dividend_events WHERE period_type = 'month');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    }
