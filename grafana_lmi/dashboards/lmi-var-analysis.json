      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT cvar_95_1m_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CVaR Trend (180d)",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, cvar_95_1d_pct AS \"CVaR 95 1d %\", cvar_95_1w_pct AS \"CVaR 95 1w %\", cvar_95_1m_pct AS \"CVaR 95 1m %\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-180 day') AND cvar_95_1d_pct IS NOT NULL ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "VaR Breach Analysis",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT period_type AS \"Period\", days_exceeding_var_95 AS \"Days > VaR 95\", ROUND(worst_day_return_pct, 2) AS \"Worst Day\", worst_day_date AS \"Date\", ROUND(best_day_return_pct, 2) AS \"Best Day\", best_day_date AS \"Date\" FROM period_summary WHERE days_exceeding_var_95 IS NOT NULL AND is_rolling = 0 ORDER BY period_end_date DESC LIMIT 8;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Period": 0, "Days > VaR 95": 1, "Worst Day": 2, "Date": 3, "Best Day": 4 },
            "renameByName": { "Date_1": "Best Date" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Period" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Days > VaR 95" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Worst Day" }, "properties": [{ "id": "custom.width", "value": 110 }] },
          { "matcher": { "id": "byName", "options": "Date" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Best Day" }, "properties": [{ "id": "custom.width", "value": 110 }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "VaR to Income Ratio (180d)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, cvar_to_income_ratio AS \"CVaR / Income Ratio\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-180 day') AND cvar_to_income_ratio IS NOT NULL ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 },
        "overrides": []
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "risk"],
  "time": { "from": "now-180d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - VaR Analysis",
  "uid": "lmi-var-analysis",
