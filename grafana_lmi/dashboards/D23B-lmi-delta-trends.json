{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Quarter-over-Quarter MV Delta Trend (4 years)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, ROUND(mv_delta, 0) AS \"Q MV Delta\" FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 0 AND mv_delta IS NOT NULL ORDER BY period_end_date DESC LIMIT 16;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Month-over-Month TWR % Trend (24 months)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, ROUND(twr_period_pct, 2) AS \"M TWR %\" FROM period_summary WHERE period_type = 'month' AND is_rolling = 0 AND twr_period_pct IS NOT NULL ORDER BY period_end_date DESC LIMIT 24;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Week-over-Week Income Trend (52 weeks)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, ROUND(dividends_received_period, 2) AS \"W Dividends\" FROM period_summary WHERE period_type = 'week' AND is_rolling = 0 AND dividends_received_period IS NOT NULL ORDER BY period_end_date DESC LIMIT 52;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 0 },
        "overrides": []
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "periods"],
  "time": { "from": "now-4y", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Delta Trends",
  "uid": "lmi-delta-trends",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-delta-trends.json" }
}
