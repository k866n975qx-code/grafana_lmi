      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(weight_pct, 1) AS \"Wt %\", ROUND(market_value, 0) AS \"MV $\", UPPER(risk_quality_category) AS \"Risk\", ROUND(var_95_1d_pct, 2) AS \"VaR 95\", ROUND(cvar_95_1d_pct, 2) AS \"CVaR 95\", ROUND(sortino_1y, 2) AS \"Sortino\" FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) AND var_95_1d_pct IS NOT NULL ORDER BY var_95_1d_pct ASC;"
        }
      ],
