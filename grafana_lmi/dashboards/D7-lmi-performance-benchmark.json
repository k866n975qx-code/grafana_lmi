    {
      "id": 11,
      "type": "timeseries",
      "title": "Portfolio vs Benchmark (365d)",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, twr_12m_pct AS \"Portfolio\", vs_benchmark_twr_1y_pct AS \"Benchmark\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-365 day') AND twr_12m_pct IS NOT NULL ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Return Attribution by Window",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 5
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT window AS \"Window\", ROUND(SUM(contribution_pct), 2) AS \"Total %\", ROUND(SUM(CASE WHEN symbol = '__INCOME__' THEN contribution_pct ELSE 0 END), 2) AS \"Income %\", ROUND(SUM(CASE WHEN symbol != '__INCOME__' THEN contribution_pct ELSE 0 END), 2) AS \"Price %\" FROM daily_return_attribution WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_return_attribution) GROUP BY window ORDER BY window;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Window": 0,
              "Total %": 1,
              "Income %": 2,
              "Price %": 3
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Window"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Income %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Price %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      }
    }
  ],
