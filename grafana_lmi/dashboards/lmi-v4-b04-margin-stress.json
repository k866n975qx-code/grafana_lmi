      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH hist AS (SELECT as_of_date_local, balance AS loan FROM margin_balance_history WHERE as_of_date_local >= date('now','-120 day')), fallback AS (SELECT as_of_date_local, margin_loan_balance AS loan FROM daily_portfolio WHERE as_of_date_local >= date('now','-120 day')), loan_series AS (SELECT as_of_date_local, loan FROM hist UNION ALL SELECT f.as_of_date_local, f.loan FROM fallback f WHERE NOT EXISTS (SELECT 1 FROM hist)) SELECT (ls.as_of_date_local || 'T00:00:00Z') AS time, ls.loan AS Loan, dp.ltv_pct AS LTVPct FROM loan_series ls LEFT JOIN daily_portfolio dp ON dp.as_of_date_local = ls.as_of_date_local ORDER BY ls.as_of_date_local",
          "rawQueryText": "WITH hist AS (SELECT as_of_date_local, balance AS loan FROM margin_balance_history WHERE as_of_date_local >= date('now','-120 day')), fallback AS (SELECT as_of_date_local, margin_loan_balance AS loan FROM daily_portfolio WHERE as_of_date_local >= date('now','-120 day')), loan_series AS (SELECT as_of_date_local, loan FROM hist UNION ALL SELECT f.as_of_date_local, f.loan FROM fallback f WHERE NOT EXISTS (SELECT 1 FROM hist)) SELECT (ls.as_of_date_local || 'T00:00:00Z') AS time, ls.loan AS Loan, dp.ltv_pct AS LTVPct FROM loan_series ls LEFT JOIN daily_portfolio dp ON dp.as_of_date_local = ls.as_of_date_local ORDER BY ls.as_of_date_local",
          "timeColumns": [
            "time"
