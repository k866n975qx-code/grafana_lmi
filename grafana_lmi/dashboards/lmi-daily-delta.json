{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Today vs Yesterday",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 14 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT 'Today' AS \"Day\", ROUND(market_value, 0) AS \"MV $\", ROUND(net_liquidation_value, 0) AS \"NLV $\", ROUND(projected_monthly_income, 2) AS \"Income\", ROUND(ltv_pct, 1) AS \"LTV %\", UPPER(portfolio_risk_quality) AS \"Risk\", ROUND(twr_1m_pct, 2) AS \"TWR 1M\" FROM daily_portfolio WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_portfolio) UNION ALL SELECT 'Yesterday', ROUND(market_value, 0), ROUND(net_liquidation_value, 0), ROUND(projected_monthly_income, 2), ROUND(ltv_pct, 1), UPPER(portfolio_risk_quality), ROUND(twr_1m_pct, 2) FROM daily_portfolio WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_portfolio WHERE as_of_date_local < (SELECT MAX(as_of_date_local) FROM daily_portfolio));"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Day": 0, "MV $": 1, "NLV $": 2, "Income": 3, "LTV %": 4, "Risk": 5, "TWR 1M": 6 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Day" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "MV $" }, "properties": [{ "id": "custom.width", "value": 130 }] },
          { "matcher": { "id": "byName", "options": "NLV $" }, "properties": [{ "id": "custom.width", "value": 130 }] },
          { "matcher": { "id": "byName", "options": "Income" }, "properties": [{ "id": "custom.width", "value": 110 }] },
          { "matcher": { "id": "byName", "options": "LTV %" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Risk" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "TWR 1M" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "daily"],
  "time": { "from": "now-2d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Daily Delta",
  "uid": "lmi-daily-delta",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-daily-delta.json" }
}
