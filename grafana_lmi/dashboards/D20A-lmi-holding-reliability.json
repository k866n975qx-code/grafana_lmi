      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(projected_monthly_dividend, 2) AS \"Monthly\", ROUND(projected_annual_dividend, 2) AS \"Annual\", ROUND(current_yield_pct, 1) AS \"Yield\", distribution_frequency AS \"Freq\", ROUND(reliability_consistency_score, 1) AS \"Score\", UPPER(reliability_trend_6m) AS \"Trend\", reliability_missed_payments_12m AS \"Missed\" FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) ORDER BY projected_monthly_dividend DESC;"
        }
      ],
