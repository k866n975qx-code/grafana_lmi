{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Next Ex Date",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT MIN(next_ex_date_est) AS value FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) AND next_ex_date_est IS NOT NULL;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "string" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events Next 7d",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM daily_dividends_upcoming WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_dividends_upcoming) AND ex_date_est >= DATE('now') AND ex_date_est < DATE('now', '+7 day');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Est Income Next 30d",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(SUM(amount_est), 2) AS value FROM daily_dividends_upcoming WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_dividends_upcoming) AND pay_date_est >= DATE('now') AND pay_date_est < DATE('now', '+30 day');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Est Income Next 90d",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(SUM(amount_est), 2) AS value FROM daily_dividends_upcoming WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_dividends_upcoming) AND pay_date_est >= DATE('now') AND pay_date_est < DATE('now', '+90 day');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Upcoming Dividends",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 11 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ex_date_est AS \"Date\", symbol AS \"Symbol\", ROUND(amount_est, 2) AS \"Amount $\", pay_date_est AS \"Pay Date\" FROM daily_dividends_upcoming WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_dividends_upcoming) ORDER BY ex_date_est, symbol LIMIT 20;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Date": 0, "Symbol": 1, "Amount $": 2, "Pay Date": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Date" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Symbol" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Amount $" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Pay Date" }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "income"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Income Overview: Calendar",
  "uid": "lmi-income-calendar",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-income-calendar.json" }
}
