{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Contributions (Month)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT contribution_date AS \"Date\", ROUND(amount, 2) AS \"Amount\", account_id AS \"Account\" FROM period_contributions WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_contributions WHERE period_type = 'month') ORDER BY contribution_date DESC;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Date": 0, "Amount": 1, "Account": 2 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Date" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Amount" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Account" }, "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Withdrawals (Month)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT withdrawal_date AS \"Date\", ROUND(amount, 2) AS \"Amount\", account_id AS \"Account\" FROM period_withdrawals WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_withdrawals WHERE period_type = 'month') ORDER BY withdrawal_date DESC;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Date": 0, "Amount": 1, "Account": 2 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Date" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Amount" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Account" }, "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Net Cash Flow (Month)",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND((SELECT COALESCE(SUM(amount), 0) FROM period_contributions WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_contributions WHERE period_type = 'month')) - (SELECT COALESCE(SUM(amount), 0) FROM period_withdrawals WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_withdrawals WHERE period_type = 'month')), 2) AS value;"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Contributions (Month)",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COALESCE(SUM(amount), 0) AS value FROM period_contributions WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_contributions WHERE period_type = 'month');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Withdrawals (Month)",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COALESCE(SUM(amount), 0) AS value FROM period_withdrawals WHERE period_type = 'month' AND period_end_date = (SELECT MAX(period_end_date) FROM period_withdrawals WHERE period_type = 'month');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 }, "overrides": [] }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "activity"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Cash Flows",
  "uid": "lmi-cash-flows",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-cash-flows.json" }
}
