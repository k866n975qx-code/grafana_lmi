    {
      "id": 11,
      "type": "table",
      "title": "Top Holdings Compact",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 4
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(h.symbol,1,8) AS Sym, round(h.market_value,0) AS MV, round(h.weight_pct,2) AS WtPct, round(h.projected_monthly_dividend,2) AS MoInc, round(h.current_yield_pct,2) AS YieldPct, round(COALESCE(r.contribution_pct,0),3) AS Ctr1m FROM daily_holdings h LEFT JOIN daily_return_attribution r ON r.as_of_date_local=h.as_of_date_local AND r.symbol=h.symbol AND r.window='1m' WHERE h.as_of_date_local=(SELECT d FROM d) ORDER BY h.market_value DESC LIMIT 5",
          "rawQueryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(h.symbol,1,8) AS Sym, round(h.market_value,0) AS MV, round(h.weight_pct,2) AS WtPct, round(h.projected_monthly_dividend,2) AS MoInc, round(h.current_yield_pct,2) AS YieldPct, round(COALESCE(r.contribution_pct,0),3) AS Ctr1m FROM daily_holdings h LEFT JOIN daily_return_attribution r ON r.as_of_date_local=h.as_of_date_local AND r.symbol=h.symbol AND r.window='1m' WHERE h.as_of_date_local=(SELECT d FROM d) ORDER BY h.market_value DESC LIMIT 5"
        }
      ],
