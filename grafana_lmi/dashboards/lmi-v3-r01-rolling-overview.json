      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, MAX(CASE WHEN period_type='WEEK' THEN mv_delta END) AS W_MVDelta, MAX(CASE WHEN period_type='MONTH' THEN mv_delta END) AS M_MVDelta, MAX(CASE WHEN period_type='QUARTER' THEN mv_delta END) AS Q_MVDelta, MAX(CASE WHEN period_type='YEAR' THEN mv_delta END) AS Y_MVDelta FROM period_summary WHERE is_rolling=1 GROUP BY period_end_date ORDER BY period_end_date",
          "rawQueryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, MAX(CASE WHEN period_type='WEEK' THEN mv_delta END) AS W_MVDelta, MAX(CASE WHEN period_type='MONTH' THEN mv_delta END) AS M_MVDelta, MAX(CASE WHEN period_type='QUARTER' THEN mv_delta END) AS Q_MVDelta, MAX(CASE WHEN period_type='YEAR' THEN mv_delta END) AS Y_MVDelta FROM period_summary WHERE is_rolling=1 GROUP BY period_end_date ORDER BY period_end_date"
        }
