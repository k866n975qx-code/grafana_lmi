{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Mean Time to Close (hrs)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(AVG((julianday(updated_at_utc) - julianday(created_at_utc)) * 24), 1) AS value FROM alert_messages WHERE status = 'closed' AND updated_at_utc IS NOT NULL AND DATE(updated_at_utc) >= DATE('now', '-30 day');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Critical Closure Rate %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(100.0 * COUNT(CASE WHEN status = 'closed' AND severity >= 8 THEN 1 END) * 1.0 / COUNT(*), 1) AS value FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-30 day');"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open Alerts Aging",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM alert_messages WHERE status = 'open' AND datetime(created_at_utc) < datetime('now', '-24 hour');"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Oldest Open (hrs)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND(MAX((julianday('now') - julianday(created_at_utc)) * 24), 1) AS value FROM alert_messages WHERE status = 'open';"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Resolution by Severity",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT severity AS \"Severity\", COUNT(*) AS \"Total\", SUM(CASE WHEN status = 'closed' AND DATE(updated_at_utc) >= DATE('now', '-30 day') THEN 1 ELSE 0 END) AS \"Closed (30d)\", ROUND(AVG(CASE WHEN status = 'closed' THEN (julianday(updated_at_utc) - julianday(created_at_utc)) * 24 END), 1) AS \"Mean Hrs\" FROM alert_messages WHERE DATE(created_at_utc) >= DATE('now', '-30 day') GROUP BY severity ORDER BY severity DESC;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Severity": 0, "Total": 1, "Closed (30d)": 2, "Mean Hrs": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Severity" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "Closed (30d)" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Mean Hrs" }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Open Alerts Aging Detail",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ROUND((julianday('now') - julianday(created_at_utc)) * 24, 0) AS \"Age Hrs\", category AS \"Category\", severity AS \"Sev\", UPPER(SUBSTR(title, 1, 50)) AS \"Alert\" FROM alert_messages WHERE status = 'open' ORDER BY \"Age Hrs\" DESC LIMIT 15;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Age Hrs": 0, "Category": 1, "Sev": 2, "Alert": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Age Hrs" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Category" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Sev" }, "properties": [{ "id": "custom.width", "value": 60 }] },
          { "matcher": { "id": "byName", "options": "Alert" }, "properties": [{ "id": "custom.width", "value": 400 }] }
        ]
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "alerts"],
  "time": { "from": "now-30d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Alert Center: Resolution",
  "uid": "lmi-alert-center-resolution",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-alert-center-resolution.json" }
}
