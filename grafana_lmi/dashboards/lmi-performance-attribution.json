{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Top Contributors (1m)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(contribution_pct, 2) AS \"Contribution %\" FROM daily_return_attribution WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_return_attribution) AND window = '1m' AND symbol != '__INCOME__' ORDER BY contribution_pct DESC LIMIT 8;"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "maxVizHeight": 300
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 8, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Bottom Contributors (1m)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(contribution_pct, 2) AS \"Contribution %\" FROM daily_return_attribution WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_return_attribution) AND window = '1m' AND symbol != '__INCOME__' ORDER BY contribution_pct ASC LIMIT 8;"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "maxVizHeight": 300
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": -5,
          "max": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": -3, "color": "yellow" }, { "value": -1, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Holdings Attribution (12m)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 11 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT symbol AS \"Symbol\", ROUND(contribution_pct, 2) AS \"Contrib %\", ROUND(weight_avg_pct, 2) AS \"Wt %\", ROUND(return_pct, 2) AS \"Return %\" FROM daily_return_attribution WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_return_attribution) AND window = '12m' AND symbol != '__INCOME__' ORDER BY ABS(contribution_pct) DESC LIMIT 15;"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Symbol": 0, "Contrib %": 1, "Wt %": 2, "Return %": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Symbol" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Contrib %" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Wt %" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Return %" }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "performance"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Performance: Attribution",
  "uid": "lmi-performance-attribution",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-performance-attribution.json" }
}
