    {
      "id": 11,
      "type": "table",
      "title": "Latest Macro/Risk Snapshot",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 4
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH latest AS (SELECT period_type, period_start_date, period_end_date FROM period_summary WHERE is_rolling=0 ORDER BY period_end_date DESC LIMIT 1), macro AS (SELECT 'macro' AS Scope, substr(metric,1,16) AS Metric, round(avg_val,3) AS Avg, round(min_val,3) AS Min, round(max_val,3) AS Max, (SELECT period_type FROM latest) AS PType FROM period_macro_stats WHERE (period_type,period_start_date,period_end_date) IN (SELECT period_type,period_start_date,period_end_date FROM latest) ORDER BY metric LIMIT 3), risk AS (SELECT 'risk' AS Scope, substr(metric,1,16) AS Metric, round(avg_val,3) AS Avg, round(min_val,3) AS Min, round(max_val,3) AS Max, (SELECT period_type FROM latest) AS PType FROM period_risk_stats WHERE (period_type,period_start_date,period_end_date) IN (SELECT period_type,period_start_date,period_end_date FROM latest) ORDER BY metric LIMIT 2) SELECT * FROM macro UNION ALL SELECT * FROM risk LIMIT 5",
          "rawQueryText": "WITH latest AS (SELECT period_type, period_start_date, period_end_date FROM period_summary WHERE is_rolling=0 ORDER BY period_end_date DESC LIMIT 1), macro AS (SELECT 'macro' AS Scope, substr(metric,1,16) AS Metric, round(avg_val,3) AS Avg, round(min_val,3) AS Min, round(max_val,3) AS Max, (SELECT period_type FROM latest) AS PType FROM period_macro_stats WHERE (period_type,period_start_date,period_end_date) IN (SELECT period_type,period_start_date,period_end_date FROM latest) ORDER BY metric LIMIT 3), risk AS (SELECT 'risk' AS Scope, substr(metric,1,16) AS Metric, round(avg_val,3) AS Avg, round(min_val,3) AS Min, round(max_val,3) AS Max, (SELECT period_type FROM latest) AS PType FROM period_risk_stats WHERE (period_type,period_start_date,period_end_date) IN (SELECT period_type,period_start_date,period_end_date FROM latest) ORDER BY metric LIMIT 2) SELECT * FROM macro UNION ALL SELECT * FROM risk LIMIT 5"
        }
