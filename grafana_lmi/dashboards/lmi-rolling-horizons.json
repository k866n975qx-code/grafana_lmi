        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "QTD MV $",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT mv_delta AS value FROM period_summary WHERE period_type = 'quarter' AND is_rolling = 1 ORDER BY period_end_date DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
