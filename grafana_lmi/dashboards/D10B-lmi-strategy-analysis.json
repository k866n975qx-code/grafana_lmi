{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Leverage Enabled",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT CASE WHEN ltv_pct > 0 THEN 1 ELSE 0 END AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "value": 0,
              "text": "NO",
              "color": "green"
            },
            {
              "type": "value",
              "value": 1,
              "text": "YES",
              "color": "orange"
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current LTV",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ltv_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DRIP Holdings",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT COUNT(*) AS value FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) AND distribution_frequency IN ('Monthly', 'Quarterly');"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Monthly Income",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT goal_net_current_projected_monthly AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Net Liquidation with Leverage vs Without (365d)",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, net_liquidation_value AS \"With Leverage\", (net_liquidation_value + margin_loan_balance) AS \"Without Leverage\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-365 day') ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Goal Tiers Assumptions",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT tier AS \"Tier\", name AS \"Name\", ROUND(target_monthly, 0) AS \"Target $\", ROUND(assumption_monthly_contribution, 0) AS \"Contrib $\", CASE WHEN assumption_drip_enabled = 1 THEN 'Yes' ELSE 'No' END AS \"DRIP\", ROUND(assumption_annual_appreciation_pct, 1) AS \"Appr %\", CASE WHEN assumption_ltv_maintained = 1 THEN 'Yes' ELSE 'No' END AS \"Maintain LTV\", ROUND(assumption_target_ltv_pct, 1) AS \"Target LTV\" FROM daily_goal_tiers WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_goal_tiers) ORDER BY tier;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Tier": 0,
              "Name": 1,
              "Target $": 2,
              "Contrib $": 3,
              "DRIP": 4,
              "Appr %": 5,
              "Maintain LTV": 6,
              "Target LTV": 7
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Tier"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 60
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Name"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Target $"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Contrib $"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "DRIP"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Appr %"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Maintain LTV"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Target LTV"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lmi",
    "goals"
  ],
  "time": {
    "from": "now-365d",
    "to": "now"
  },
