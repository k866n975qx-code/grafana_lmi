      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(h.symbol,1,8) AS Sym, round(h.market_value,0) AS MV, round(h.weight_pct,2) AS WtPct, round(h.projected_monthly_dividend,2) AS MoInc FROM daily_holdings h WHERE h.as_of_date_local=(SELECT d FROM d) ORDER BY h.market_value DESC LIMIT 5",
          "rawQueryText": "WITH d AS (SELECT MAX(as_of_date_local) AS d FROM daily_holdings) SELECT substr(h.symbol,1,8) AS Sym, round(h.market_value,0) AS MV, round(h.weight_pct,2) AS WtPct, round(h.projected_monthly_dividend,2) AS MoInc FROM daily_holdings h WHERE h.as_of_date_local=(SELECT d FROM d) ORDER BY h.market_value DESC LIMIT 5"
