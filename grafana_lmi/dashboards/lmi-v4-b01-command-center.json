    {
      "id": 5,
      "type": "stat",
      "title": "Day MV Delta",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 3,
        "h": 2
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "WITH latest AS (SELECT MAX(as_of_date_local) AS d FROM daily_portfolio), prev AS (SELECT MAX(as_of_date_local) AS d FROM daily_portfolio WHERE as_of_date_local < (SELECT d FROM latest)) SELECT (SELECT market_value FROM daily_portfolio WHERE as_of_date_local=(SELECT d FROM latest)) - (SELECT market_value FROM daily_portfolio WHERE as_of_date_local=(SELECT d FROM prev)) AS value",
          "rawQueryText": "WITH latest AS (SELECT MAX(as_of_date_local) AS d FROM daily_portfolio), prev AS (SELECT MAX(as_of_date_local) AS d FROM daily_portfolio WHERE as_of_date_local < (SELECT d FROM latest)) SELECT (SELECT market_value FROM daily_portfolio WHERE as_of_date_local=(SELECT d FROM latest)) - (SELECT market_value FROM daily_portfolio WHERE as_of_date_local=(SELECT d FROM prev)) AS value"
        }
      ],
