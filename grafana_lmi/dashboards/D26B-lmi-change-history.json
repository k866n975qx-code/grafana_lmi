{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Position Additions/Removals Trend (52 weeks)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, SUM(CASE WHEN list_type = 'added' THEN 1 ELSE 0 END) AS \"Added\", SUM(CASE WHEN list_type = 'removed' THEN 1 ELSE 0 END) AS \"Removed\" FROM period_position_lists WHERE period_type = 'week' AND period_end_date >= date('now','-52 week') GROUP BY period_end_date ORDER BY period_end_date;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Turnover Rate Trend (52 weeks)",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (period_end_date || 'T00:00:00Z') AS time, ROUND(100.0 * SUM(CASE WHEN list_type IN ('added', 'removed') THEN 1 ELSE 0 END) / NULLIF((SELECT COUNT(*) FROM daily_holdings dh WHERE dh.as_of_date_local <= ppl.period_end_date ORDER BY dh.as_of_date_local DESC LIMIT 1), 0), 1) AS \"Turnover %\" FROM period_position_lists ppl WHERE period_type = 'week' AND period_end_date >= date('now','-52 week') GROUP BY period_end_date ORDER BY period_end_date;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "time",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Change History by Week",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "lmi_sqlite"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT ps.period_label AS \"Week\", SUM(CASE WHEN ppl.list_type = 'added' THEN 1 ELSE 0 END) AS \"Added\", SUM(CASE WHEN ppl.list_type = 'removed' THEN 1 ELSE 0 END) AS \"Removed\", SUM(CASE WHEN ppl.list_type = 'increased' THEN 1 ELSE 0 END) AS \"Increased\", SUM(CASE WHEN ppl.list_type = 'decreased' THEN 1 ELSE 0 END) AS \"Decreased\" FROM period_summary ps LEFT JOIN period_position_lists ppl ON ppl.period_type = ps.period_type AND ppl.period_start_date = ps.period_start_date AND ppl.period_end_date = ps.period_end_date WHERE ps.period_type = 'week' AND ps.is_rolling = 0 GROUP BY ps.period_label, ps.period_end_date ORDER BY ps.period_end_date DESC LIMIT 12;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Week": 0,
              "Added": 1,
              "Removed": 2,
              "Increased": 3,
              "Decreased": 4
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Week"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Added"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Removed"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Increased"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Decreased"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "lmi",
    "holdings"
  ],
  "time": {
    "from": "now-52w",
    "to": "now"
  },
  "timezone": "browser",
  "title": "D26B - LMI - Change History",
  "uid": "lmi-d26b-change-history",
  "version": 1,
  "__annotations": {
    "grafana.app/sourcePath": "dashboards/D26B-lmi-change-history.json"
  }
}
