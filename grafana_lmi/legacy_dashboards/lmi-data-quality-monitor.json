{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Coverage %",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT coverage_derived_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 95, "color": "yellow" }, { "value": 98, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Missing %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT coverage_missing_pct AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 2, "color": "yellow" }, { "value": 5, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Health Status",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT UPPER(health_status) AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string",
          "mappings": [
            { "type": "value", "value": "HEALTHY", "text": "HEALTHY", "color": "green" },
            { "type": "value", "value": "DEGRADED", "text": "DEGRADED", "color": "yellow" },
            { "type": "value", "value": "UNHEALTHY", "text": "UNHEALTHY", "color": "red" }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Snapshot Date",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT as_of_date_local AS value FROM daily_portfolio ORDER BY as_of_date_local DESC LIMIT 1;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "string" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Coverage Trend (90d)",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, coverage_derived_pct AS \"Derived %\", coverage_missing_pct AS \"Missing %\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-90 day') ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conclusions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Holdings Count (90d)",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT (as_of_date_local || 'T00:00:00Z') AS time, holdings_count AS \"Holdings Count\" FROM daily_portfolio WHERE as_of_date_local >= date('now','-90 day') ORDER BY as_of_date_local;"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": { "conversions": [{ "targetField": "time", "destinationType": "time" }] }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Data Quality Summary",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "lmi_sqlite" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "queryType": "table",
          "queryText": "SELECT 'Holdings Count' AS \"Metric\", (SELECT COUNT(*) FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings)) AS \"Today\", (SELECT COUNT(*) FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) AND current_yield_pct IS NOT NULL) AS \"With Price\", (SELECT COUNT(*) FROM daily_holdings WHERE as_of_date_local = (SELECT MAX(as_of_date_local) FROM daily_holdings) AND reliability_consistency_score IS NOT NULL) AS \"Reliability\" UNION ALL SELECT 'Period Summaries', (SELECT COUNT(*) FROM period_summary WHERE twr_period_pct IS NOT NULL) AS \"Today\", (SELECT COUNT(*) FROM period_summary WHERE dividends_received_period IS NOT NULL) AS \"With Divs\", (SELECT COUNT(*) FROM period_summary WHERE portfolio_risk_quality_end IS NOT NULL) AS \"With Risk\" UNION ALL SELECT 'Alert Messages', (SELECT COUNT(*) FROM alert_messages WHERE as_of_date_local >= DATE('now', '-7 day')) AS \"7d\", (SELECT COUNT(*) FROM alert_messages WHERE status = 'open') AS \"Open\", (SELECT COUNT(*) FROM alert_messages WHERE status = 'closed' AND DATE(updated_at_utc) >= DATE('now', '-7 day')) AS \"Closed 7d\";"
        }
      ],
      "options": { "showHeader": true, "cellHeight": "sm" },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Metric": 0, "Today": 1, "With Price": 2, "Reliability": 3 },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Metric" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "Today" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "With Price" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Reliability" }, "properties": [{ "id": "custom.width", "value": 120 }] }
        ]
      }
    }
  ],
  "refresh": "2m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["lmi", "system"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "title": "LMI - Data Quality Monitor",
  "uid": "lmi-data-quality-monitor",
  "version": 1,
  "__annotations": { "grafana.app/sourcePath": "dashboards/lmi-data-quality-monitor.json" }
}
